<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background:#0d0d0d;
    color:white;
    overflow-x:hidden;
}

nav{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:25px 10%;
    position:fixed;
    width:100%;
    background:rgba(0,0,0,.7);
    backdrop-filter:blur(10px);
    z-index:1000;
}

.logo{
    font-size:1.5rem;
    font-weight:700;
    color:#00aaff;
}

nav ul{
    display:flex;
    list-style:none;
    gap:30px;
}

nav a{
    text-decoration:none;
    color:white;
    transition:.3s;
}

nav a:hover{
    color:#00aaff;
}

.hero{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    flex-direction:column;
    padding:20px;
}

.hero h1{
    font-size:4rem;
}

.hero h1 span{
    color:#00aaff;
}

.hero p{
    margin-top:15px;
    color:#aaa;
    max-width:700px;
}

.btn{
    margin-top:30px;
    padding:15px 35px;
    background:#00aaff;
    color:white;
    text-decoration:none;
    border-radius:50px;
    transition:.3s;
}

.btn:hover{
    transform:translateY(-3px);
    box-shadow:0 0 20px #00aaff;
}

section{
    padding:100px 10%;
}

.title{
    font-size:2.5rem;
    margin-bottom:40px;
    text-align:center;
    color:#00aaff;
}

.about{
    text-align:center;
    max-width:800px;
    margin:auto;
    color:#bbb;
}

.skills{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
    gap:20px;
}

.skill{
    background:#141414;
    padding:25px;
    border-radius:15px;
    text-align:center;
    transition:.3s;
}

.skill:hover{
    transform:translateY(-5px);
    box-shadow:0 0 15px rgba(0,170,255,.4);
}

.projects{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:25px;
}

.project{
    background:#141414;
    border-radius:15px;
    overflow:hidden;
    transition:.3s;
}

.project img{
    width:100%;
    height:220px;
    object-fit:cover;
}

.project-content{
    padding:20px;
}

.project:hover{
    transform:translateY(-8px);
}

.contact{
    text-align:center;
}

.contact a{
    color:#00aaff;
    text-decoration:none;
}

footer{
    text-align:center;
    padding:30px;
    color:#777;
    border-top:1px solid #222;
}

@media(max-width:768px){
.hero h1{
font-size:2.5rem;
}
}
</style>
</head>

